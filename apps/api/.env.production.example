# AgentOps Observer API - Production Environment Variables
# Optimized for 100% FREE tier deployment (Supabase + Upstash + Render)
# Copy this file to .env.production.local and fill in your values

# ============================================================================
# SUPABASE DATABASE (Free tier: 500MB, 2 direct connections)
# Get from: Supabase Dashboard → Settings → Database → Connection string
# ============================================================================
POSTGRES_HOST=aws-0-us-east-1.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres.your-project-id
POSTGRES_PASSWORD=your-supabase-password

# Alternative: Full DATABASE_URL (used by some tools)
# DATABASE_URL=postgresql://postgres.your-project-id:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ============================================================================
# UPSTASH REDIS (Free tier: 10,000 commands/day, 256MB)
# Get from: Upstash Console → Create Database → REST API
# ============================================================================
UPSTASH_REDIS_REST_URL=https://your-region-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Standard Redis (leave empty if using Upstash)
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# ============================================================================
# KAFKA (optional - disable for free tier)
# ============================================================================
# KAFKA_BOOTSTRAP_SERVERS=
# KAFKA_CONSUMER_GROUP=agentops-api

# ============================================================================
# SECURITY
# Generate secret: openssl rand -hex 32
# ============================================================================
JWT_SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Your Vercel frontend URL
CORS_ORIGINS=["https://your-app.vercel.app"]

# ============================================================================
# AI PROVIDERS (for semantic analysis - optional)
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# FREE TIER NOTES
# ============================================================================
# Supabase Free Tier Limits:
#   - 500MB database storage
#   - 2 direct database connections
#   - 1GB bandwidth per month
#
# Upstash Free Tier Limits:
#   - 10,000 commands per day
#   - 256MB storage
#   - 100 concurrent connections
#
# Render Free Tier Limits:
#   - 750 hours/month (enough for 1 service 24/7)
#   - Service sleeps after 15 min inactivity
#   - Cold start takes ~30 seconds
#   - Use GitHub Actions keep-alive workflow to stay warm
