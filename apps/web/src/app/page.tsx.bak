                  </div>
                  <div className="space-y-1.5 mb-2">
                    <div className="h-1.5 bg-muted/50 rounded-full overflow-hidden">
                      <div
                        className={cn(
                          "h-full rounded-full transition-all duration-500",
                          budgetStatus === "critical" ? "bg-red-500" :
