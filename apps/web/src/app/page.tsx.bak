                    <a href="/agents" className="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 transition-colors">
                      View all <ArrowUpRight className="h-3 w-3" />
                    </a>
                  </div>
                </CardHeader>
                <CardContent className="pt-0 px-2 pb-2">
                  <div className="space-y-1">
                    {agentHealth.map((agent, index) => (
                      <div
                        key={agent.name}
                        className={cn(
                          "rounded-md border border-border/50 p-3 transition-all cursor-pointer table-row-hover animate-fade-in-up",
                          `stagger-${Math.min(index + 1, 6)}`,
                          recentAgentPulse === agent.name && "ring-2 ring-primary/50 ring-offset-2 ring-offset-background"
                        )}
                      >
                        <div className="flex items-start justify-between mb-2">
                          <div className="flex items-center gap-2">
                            <HealthDot health={agent.health} />
                            <span className="text-sm font-medium">{agent.name}</span>
                          </div>
                          <FrameworkBadge framework={agent.framework} />
                        </div>
                        <div className="flex items-center justify-between">
                          <div className="text-xs text-muted-foreground">
                            <RelativeTime date={agent.last_execution} /> — {" "}
                            <span className={cn(
                              agent.last_status === "completed" && "text-emerald-500",
                              agent.last_status === "failed" && "text-red-500",
                              agent.last_status === "running" && "text-blue-500"
                            )}>
                              {agent.last_status === "completed" ? "Success" : 
                               agent.last_status === "failed" ? "Failed" : "Running"}
                            </span>
                          </div>
                          <div className="flex items-center gap-3">
                            <div className="w-14 h-5">
                              <MiniSparkline 
                                data={agent.sparkline} 
                                color={agent.health === "healthy" ? "#10b981" : agent.health === "degraded" ? "#f59e0b" : "#ef4444"}
                                height={20}
                              />
                            </div>
                            <span className="text-xs font-mono tabular-nums text-muted-foreground">
                              ${agent.cost_today.toFixed(2)}
                            </span>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </CardContent>
              </Card>
            </div>

            {/* ================================================================ */}
            {/* BOTTOM SECTION — Three columns */}
            {/* ================================================================ */}
            <div className="grid gap-4 md:grid-cols-3">
              {/* Left: Cost by Project (Donut chart) */}
              <Card className="card-hover animate-fade-in-up stagger-6">
                <CardHeader className="pb-2 pt-4 px-4">
                  <CardTitle className="flex items-center gap-2 text-sm font-medium">
                    <DollarSign className="h-4 w-4 text-muted-foreground" />
                    Cost by Project
                  </CardTitle>
                </CardHeader>
                <CardContent className="pt-0 px-4 pb-4">
                  <div className="flex items-center justify-center h-40">
                    <ResponsiveContainer width="100%" height="100%">
                      <PieChart>
                        <Pie
                          data={costByProject}
                          cx="50%"
                          cy="50%"
                          innerRadius={45}
                          outerRadius={65}
                          paddingAngle={2}
                          dataKey="value"
                        >
                          {costByProject.map((entry, index) => (
                            <Cell key={`cell-${index}`} fill={entry.color} />
                          ))}
                        </Pie>
                        <Tooltip
                          content={({ active, payload }) => {
                            if (active && payload && payload.length) {
                              const data = payload[0].payload;
                              return (
                                <div className="rounded-md border bg-popover px-3 py-2 text-xs shadow-md">
                                  <p className="font-medium">{data.name}</p>
                                  <p className="text-muted-foreground">${data.value.toFixed(2)}</p>
                                </div>
                              );
                            }
                            return null;
                          }}
                        />
                      </PieChart>
                    </ResponsiveContainer>
                  </div>
                  <div className="space-y-1.5 mt-2">
                    {costByProject.slice(0, 4).map((project) => (
                      <div key={project.name} className="flex items-center justify-between text-xs">
                        <div className="flex items-center gap-2">
                          <span className="h-2 w-2 rounded-full" style={{ backgroundColor: project.color }} />
                          <span className="text-muted-foreground">{project.name}</span>
                        </div>
                        <span className="font-mono tabular-nums">${project.value.toFixed(0)}</span>
                      </div>
                    ))}
                  </div>
                </CardContent>
              </Card>

              {/* Center: Execution Volume 7d (Area chart) */}
              <Card className="card-hover animate-fade-in-up stagger-6">
                <CardHeader className="pb-2 pt-4 px-4">
                  <CardTitle className="flex items-center gap-2 text-sm font-medium">
                    <Zap className="h-4 w-4 text-muted-foreground" />
                    Execution Volume (7d)
                  </CardTitle>
                </CardHeader>
                <CardContent className="pt-0 px-4 pb-4">
                  <div className="h-52">
                    <ResponsiveContainer width="100%" height="100%">
                      <AreaChart data={executionVolume7d}>
                        <defs>
                          <linearGradient id="executionGradient" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="5%" stopColor="#3b82f6" stopOpacity={0.3} />
                            <stop offset="95%" stopColor="#3b82f6" stopOpacity={0} />
                          </linearGradient>
                        </defs>
                        <XAxis
                          dataKey="day"
                          axisLine={false}
                          tickLine={false}
                          tick={{ fill: "#6b7280", fontSize: 10 }}
                        />
                        <YAxis hide />
                        <Tooltip
                          content={({ active, payload, label }) => {
                            if (active && payload && payload.length) {
                              return (
                                <div className="rounded-md border bg-popover px-3 py-2 text-xs shadow-md">
                                  <p className="font-medium mb-1">{label}</p>
                                  <p className="text-muted-foreground">{payload[0].value} executions</p>
                                  <p className="text-muted-foreground">${(payload[0].payload as any).cost.toFixed(2)} cost</p>
                                </div>
                              );
                            }
                            return null;
                          }}
                        />
                        <Area
                          type="monotone"
                          dataKey="executions"
                          stroke="#3b82f6"
                          strokeWidth={2}
                          fill="url(#executionGradient)"
                        />
                      </AreaChart>
                    </ResponsiveContainer>
                  </div>
                </CardContent>
              </Card>

              {/* Right: Recent Incidents */}
              <Card className="card-hover animate-fade-in-up stagger-6">
                <CardHeader className="pb-2 pt-4 px-4">
                  <div className="flex items-center justify-between">
                    <CardTitle className="flex items-center gap-2 text-sm font-medium">
                      <AlertTriangle className="h-4 w-4 text-muted-foreground" />
                      Recent Incidents
                    </CardTitle>
                    <a href="/incidents" className="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 transition-colors">
                      View all <ArrowUpRight className="h-3 w-3" />
                    </a>
                  </div>
                </CardHeader>
                <CardContent className="pt-0 px-2 pb-2">
                  <div className="space-y-0.5">
                    {recentIncidents.map((incident, index) => (
                      <div
                        key={incident.id}
                        className={cn(
                          "flex items-start gap-3 rounded-md px-2 py-2 table-row-hover cursor-pointer animate-fade-in-up",
                          `stagger-${Math.min(index + 1, 6)}`
                        )}
                      >
                        <div className={cn(
                          "w-1 h-full min-h-[36px] rounded-full shrink-0",
                          incident.severity === "critical" && "bg-red-500",
                          incident.severity === "warning" && "bg-amber-500",
                          incident.severity === "low" && "bg-blue-500"
                        )} />
                        <div className="flex-1 min-w-0">
                          <p className="text-sm font-medium truncate">{incident.title}</p>
                          <div className="flex items-center gap-2 mt-0.5">
                            <SeverityBadge severity={incident.severity as any} />
                            <RelativeTime date={incident.created_at} className="text-[10px]" />
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </CardContent>
              </Card>
            </div>
          </div>
        </main>
      </div>
    </div>
  );
}
