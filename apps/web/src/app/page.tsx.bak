                      </>
                    ) : (
                      <>
                        <AlertTriangle className="h-3 w-3" />
                        {budgetPercentage.toFixed(0)}% of budget used
                      </>
                    )}
                  </div>
                </CardContent>
              </Card>

              {/* Card 4: Open Incidents */}
              <Card className={cn(
                "metric-card animate-fade-in-up stagger-4",
                metrics.critical_incidents > 0 && "border-red-500/30"
