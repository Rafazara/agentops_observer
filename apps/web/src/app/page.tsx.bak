                      </div>
                      <p className="text-xs text-muted-foreground">No active incidents</p>
                    </>
                  ) : (
                    <>
                      <div className="flex items-center gap-3 mb-3">
                        <span className="text-3xl font-semibold tabular-nums">
                          <CountUpNumber value={metrics.open_incidents} />
                        </span>
                        {metrics.critical_incidents > 0 && (
                          <span className="relative flex h-3 w-3">
                            <span className="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-500 opacity-75" />
                            <span className="relative inline-flex h-3 w-3 rounded-full bg-red-500" />
                          </span>
                        )}
                      </div>
                      <div className="flex flex-wrap gap-1 text-xs">
                        {metrics.critical_incidents > 0 && (
                          <span className="inline-flex items-center rounded border-l-2 border-l-red-500 bg-red-500/10 px-2 py-0.5 text-red-500 font-medium">
                            {metrics.critical_incidents} critical
                          </span>
