// ============================================================================
// COMPONENTS
// ============================================================================

function MiniSparkline({ data, color = "#3b82f6", height = 24 }: { data: number[]; color?: string; height?: number }) {
  const chartData = data.map((value, i) => ({ i, value }));
  return (
    <ResponsiveContainer width="100%" height={height}>
      <LineChart data={chartData}>
        <Line
          type="monotone"
          dataKey="value"
          stroke={color}
          strokeWidth={1.5}
          dot={false}
        />
      </LineChart>
    </ResponsiveContainer>
  );
}

function MiniBarChart({ data }: { data: typeof executionsByHour }) {
  return (
    <ResponsiveContainer width="100%" height={32}>
      <BarChart data={data} barGap={2}>
        <Bar dataKey="success" fill="#10b981" radius={[2, 2, 0, 0]} />
        <Bar dataKey="failed" fill="#ef4444" radius={[2, 2, 0, 0]} />
      </BarChart>
    </ResponsiveContainer>
  );
}

function FrameworkBadge({ framework }: { framework: string }) {
  const config: Record<string, { label: string; icon: string; color: string }> = {
    langchain: { label: "LangChain", icon: "🦜", color: "bg-emerald-500/10 text-emerald-500 border-emerald-500/20" },
    openai: { label: "OpenAI", icon: "◯", color: "bg-blue-500/10 text-blue-500 border-blue-500/20" },
    anthropic: { label: "Anthropic", icon: "◈", color: "bg-amber-500/10 text-amber-500 border-amber-500/20" },
  };
  const { label, icon, color } = config[framework] || { label: framework, icon: "⚡", color: "bg-muted text-muted-foreground" };
  
  return (
    <span className={cn("inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] border font-medium", color)}>
      <span>{icon}</span>
      {label}
    </span>
  );
}

function HealthDot({ health }: { health: string }) {
  const colors: Record<string, string> = {
    healthy: "bg-emerald-500",
    degraded: "bg-amber-500",
    critical: "bg-red-500",
  };
  const pulseColors: Record<string, string> = {
    healthy: "bg-emerald-500",
    degraded: "bg-amber-500",
    critical: "bg-red-500",
  };
  
  return (
    <span className="relative flex h-2.5 w-2.5">
      {health !== "healthy" && (
        <span className={cn("absolute inline-flex h-full w-full animate-ping rounded-full opacity-75", pulseColors[health])} />
      )}
      <span className={cn("relative inline-flex h-2.5 w-2.5 rounded-full", colors[health])} />
    </span>
  );
}

// ============================================================================
// MAIN DASHBOARD
// ============================================================================

export default function DashboardPage() {
  const [isLoading, setIsLoading] = useState(true);
  const [recentAgentPulse, setRecentAgentPulse] = useState<string | null>(null);

  // Simulate loading
  useEffect(() => {
    const timer = setTimeout(() => setIsLoading(false), 800);
    return () => clearTimeout(timer);
  }, []);

  // Simulate agent pulse effect when new execution comes in
  useEffect(() => {
    const interval = setInterval(() => {
      const randomAgent = agentHealth[Math.floor(Math.random() * agentHealth.length)];
      setRecentAgentPulse(randomAgent.name);
      setTimeout(() => setRecentAgentPulse(null), 1500);
    }, 5000);
    return () => clearInterval(interval);
  }, []);

  const executionChange = useMemo(() => {
    const change = ((metrics.executions_today - metrics.executions_yesterday) / metrics.executions_yesterday) * 100;
    return { value: Math.abs(change).toFixed(1), positive: change >= 0 };
  }, []);

  const budgetPercentage = (metrics.cost_month / metrics.budget_month) * 100;
  const budgetStatus = budgetPercentage >= 90 ? "critical" : budgetPercentage >= 75 ? "warning" : "ok";

  if (isLoading) {
    return (
      <div className="flex h-screen">
        <Sidebar />
        <div className="flex flex-1 flex-col overflow-hidden">
          <Header />
          <main className="flex-1 overflow-auto p-6">
            <DashboardSkeleton />
          </main>
        </div>
      </div>
    );
  }

  return (
    <div className="flex h-screen">
      <Sidebar />
      <div className="flex flex-1 flex-col overflow-hidden">
        <Header />
        <main className="flex-1 overflow-auto p-5">
          <div className="space-y-5 animate-fade-in">
            {/* Page header */}
            <div className="flex items-center justify-between">
              <div>
                <h1 className="text-xl font-semibold tracking-tight">Mission Control</h1>
                <p className="text-xs text-muted-foreground">
                  Real-time overview of your AI agent fleet
                </p>
              </div>
              <div className="flex items-center gap-2 text-xs text-muted-foreground">
                <span className="relative flex h-2 w-2">
                  <span className="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75" />
                  <span className="relative inline-flex h-2 w-2 rounded-full bg-emerald-500" />
                </span>
                Live
              </div>
            </div>

            {/* ================================================================ */}
            {/* TOP SECTION — Hero metrics row (4 cards) */}
            {/* ================================================================ */}
            <div className="grid gap-3 md:grid-cols-2 lg:grid-cols-4">
              {/* Card 1: Active Agents */}
              <Card className="metric-card animate-fade-in-up stagger-1">
                <CardContent className="p-4">
                  <div className="flex items-center justify-between mb-2">
                    <span className="text-xs font-medium text-muted-foreground uppercase tracking-wider">
                      Active Agents
                    </span>
                    <Bot className="h-4 w-4 text-muted-foreground/50" />
                  </div>
                  <div className="flex items-center gap-3 mb-3">
                    <span className="text-3xl font-semibold tabular-nums">
                      <CountUpNumber value={metrics.active_agents} />
                    </span>
                    <div className="flex gap-1">
                      {Array.from({ length: Math.min(metrics.running_now, 5) }).map((_, i) => (
                        <span key={i} className="relative flex h-2 w-2">
                          <span className="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75" style={{ animationDelay: `${i * 200}ms` }} />
                          <span className="relative inline-flex h-2 w-2 rounded-full bg-emerald-500" />
                        </span>
                      ))}
                    </div>
                  </div>
                  <div className="h-6 mb-2">
                    <MiniSparkline data={activityData24h.map(d => d.value)} color="#10b981" />
                  </div>
                  <p className="text-xs text-muted-foreground">
                    <span className="text-emerald-500 font-medium">{metrics.running_now} running</span> now
                  </p>
                </CardContent>
              </Card>

              {/* Card 2: Executions Today */}
              <Card className="metric-card animate-fade-in-up stagger-2">
                <CardContent className="p-4">
                  <div className="flex items-center justify-between mb-2">
                    <span className="text-xs font-medium text-muted-foreground uppercase tracking-wider">
                      Executions Today
                    </span>
                    <Activity className="h-4 w-4 text-muted-foreground/50" />
                  </div>
                  <div className="flex items-center gap-2 mb-3">
                    <span className="text-3xl font-semibold tabular-nums">
                      <CountUpNumber value={metrics.executions_today} />
                    </span>
                    <span className="inline-flex items-center rounded border-l-2 border-l-emerald-500 bg-emerald-500/10 px-2 py-0.5 text-xs font-medium text-emerald-500">
                      {metrics.success_rate}%
                    </span>
                  </div>
                  <div className="h-8 mb-2">
                    <MiniBarChart data={executionsByHour} />
                  </div>
                  <div className="flex items-center gap-1 text-xs">
                    {executionChange.positive ? (
                      <>
