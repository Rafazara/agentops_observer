                    </div>
                    <div className="flex justify-between text-[10px] text-muted-foreground">
                      <span className="tabular-nums">${metrics.cost_month.toFixed(0)} spent</span>
                      <span className="tabular-nums">${metrics.budget_month.toFixed(0)} budget</span>
                    </div>
                  </div>
                  <div className={cn(
                    "text-xs flex items-center gap-1",
                    budgetStatus === "critical" ? "text-red-500" :
                    budgetStatus === "warning" ? "text-amber-500" : "text-emerald-500"
                  )}>
                    {budgetStatus === "ok" ? (
                      <>
                        <CheckCircle2 className="h-3 w-3" />
