# AgentOps Observer - Production Environment Variables
# Optimized for 100% FREE tier deployment (Vercel + Render)
# Copy this file to .env.production.local and fill in your values

# ============================================================================
# API CONFIGURATION
# Point to your Render.com API deployment
# ============================================================================
NEXT_PUBLIC_API_URL=https://agentops-api.onrender.com
NEXT_PUBLIC_WS_URL=wss://agentops-api.onrender.com

# ============================================================================
# DEMO MODE
# Set to "true" for demo/investor link (shows sample data, limits writes)
# ============================================================================
NEXT_PUBLIC_DEMO_MODE=true

# ============================================================================
# AUTH CONFIGURATION
# Generate secret: openssl rand -hex 32
# ============================================================================
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
NEXTAUTH_URL=https://your-app.vercel.app

# ============================================================================
# ANALYTICS (optional)
# ============================================================================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ============================================================================
# FREE TIER NOTES
# ============================================================================
# Vercel Free Tier (Hobby):
#   - 100GB bandwidth per month
#   - Serverless function executions: 100GB-hours
#   - Builds: 6000 minutes/month
#
# Note: First request to API may be slow (~30s) if Render service is sleeping
# Consider using the keep-alive GitHub Action to prevent cold starts
