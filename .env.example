# ============================================================================
# AgentOps Observer - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================================

# ============================================================================
# APPLICATION
# ============================================================================

# Environment: development, staging, production
APP_ENV=development

# Secret key for JWT signing (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-64-char-hex-string-in-production

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# Collector host and port
COLLECTOR_HOST=0.0.0.0
COLLECTOR_PORT=8001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# DATABASE (PostgreSQL + TimescaleDB)
# ============================================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=agentops
POSTGRES_PASSWORD=agentops_secret
POSTGRES_DB=agentops

# Connection pool settings
POSTGRES_POOL_SIZE=10
POSTGRES_POOL_MAX_OVERFLOW=20

# Full database URL (alternative to individual settings)
# DATABASE_URL=postgresql://agentops:agentops_secret@localhost:5432/agentops

# ============================================================================
# REDIS
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Full Redis URL (alternative to individual settings)
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# KAFKA (Redpanda)
# ============================================================================

KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_CONSUMER_GROUP_ID=agentops-consumer
KAFKA_AUTO_OFFSET_RESET=earliest

# Topic names
KAFKA_TOPIC_EVENTS_RAW=agentops.events.raw
KAFKA_TOPIC_EVENTS_PROCESSED=agentops.events.processed
KAFKA_TOPIC_EXECUTIONS_COMPLETED=agentops.executions.completed
KAFKA_TOPIC_INCIDENTS=agentops.incidents.created
KAFKA_TOPIC_DLQ=agentops.dlq

# ============================================================================
# ANTHROPIC API (for Semantic Analysis)
# ============================================================================

# Required for semantic analysis features
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model to use for analysis (claude-haiku-4-5-20251001 recommended)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ============================================================================
# AUTHENTICATION
# ============================================================================

# JWT token expiration (in minutes/days)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Password hashing
PASSWORD_HASH_ROUNDS=12

# API key prefix (shown to users)
API_KEY_PREFIX=agentops_sk_

# ============================================================================
# RATE LIMITING
# ============================================================================

# Global rate limits (requests per minute)
RATE_LIMIT_DEFAULT=1000
RATE_LIMIT_INGEST=10000
RATE_LIMIT_AUTH=60

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable features
FEATURE_SEMANTIC_ANALYSIS=true
FEATURE_ANOMALY_DETECTION=true
FEATURE_PII_REDACTION=true
FEATURE_AUDIT_LOGGING=true

# ============================================================================
# EXTERNAL INTEGRATIONS (Optional)
# ============================================================================

# Slack (for alerts)
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# PagerDuty (for alerts)
PAGERDUTY_ROUTING_KEY=

# OpsGenie (for alerts)
OPSGENIE_API_KEY=

# ============================================================================
# MONITORING & OBSERVABILITY (Self)
# ============================================================================

# Prometheus metrics endpoint
METRICS_ENABLED=true
METRICS_PORT=9090

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# Sentry (error tracking)
SENTRY_DSN=

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Enable debug mode (never in production!)
DEBUG=true

# Enable SQL query logging
LOG_SQL_QUERIES=false

# Disable authentication for testing (NEVER in production!)
DISABLE_AUTH=false
